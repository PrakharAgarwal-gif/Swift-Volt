# Database Configuration (Required for Prisma)
# If deploying on Render, this is provided automatically if you link a database.
DATABASE_URL="postgresql://user:password@localhost:5432/swiftvolt"

PORT=3001
JWT_SECRET=super-secret-key-swift-volt

# OpenAI API Key (For AI Assistant)
OPENAI_API_KEY=your_openai_api_key_here

# SMTP Configuration (For Email Notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
ADMIN_EMAIL=admin@swiftvolt.com
