// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String
  password  String
  role      String   @default("DEALER") // ADMIN or DEALER
  dealer    Dealer?
  createdAt DateTime @default(now())
}

model Dealer {
  id               String   @id @default(uuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id])
  companyName      String
  address          String
  stock            Int      @default(0)
  performanceScore Float    @default(0.0)
  orders           Order[]
  sales            Sale[]
  sparePartOrders  SparePartOrder[]
}

model Scooter {
  id                    String   @id @default(uuid())
  model                 String   @unique
  category              String   @default("Standard") // Standard, Special, Commercial
  description           String?
  features              String?  // JSON string or comma-separated
  batteryCapacity       String?
  motorPower            String?
  maxSpeed              String?
  range                 String?
  chargingTime          String?
  controller            String?
  tyreSize              String?
  brakeType             String?
  suspension            String?
  weight                String?
  payload               String?
  colors                String?  // JSON array
  warrantyPeriod        String?
  dealerPrice           Float    @default(0.0)
  distributorPrice      Float    @default(0.0)
  retailPrice           Float    @default(0.0)
  manufacturingLeadTime String?  // e.g. "7 Days"
  quantity              Int      @default(0) // Available Stock
  imageUrl              String?
  brochureUrl           String?
}

model Order {
  id              String   @id @default(uuid())
  dealerId        String
  dealer          Dealer   @relation(fields: [dealerId], references: [id])
  scooterModel    String
  quantity        Int
  color           String
  accessories     String?  // JSON string
  deliveryAddress String
  paymentOption   String
  status          String   @default("Order Confirmed") // 14 steps
  trackingId      String?
  expectedArrival DateTime?
  
  // Dispatch Details
  transportCompany String?
  driverName       String?
  driverMobile     String?
  vehicleNumber    String?
  lrNumber         String?
  dispatchDate     DateTime?
  
  invoice         Invoice?
  vehicles        Vehicle[] // Manufactured units
  createdAt       DateTime @default(now())
}

model Vehicle {
  id               String    @id @default(uuid())
  orderId          String
  order            Order     @relation(fields: [orderId], references: [id])
  scooterModel     String
  chassisNumber    String    @unique
  motorNumber      String    @unique
  batteryNumber    String    @unique
  controllerNumber String    @unique
  batchNumber      String
  productionDate   DateTime
  inspectionStatus String    @default("Pending") // Pending, Passed, Failed
  qrCodeData       String?
  warranty         Warranty?
}

model Warranty {
  id                String   @id @default(uuid())
  vehicleId         String   @unique
  vehicle           Vehicle  @relation(fields: [vehicleId], references: [id])
  dealerName        String
  purchaseDate      DateTime
  warrantyStartDate DateTime
  warrantyExpiryDate DateTime
  status            String   @default("Active") // Active, Claimed, Expired
}

model SparePart {
  id          String   @id @default(uuid())
  name        String
  category    String
  price       Float
  stock       Int      @default(0)
  description String?
  imageUrl    String?
}

model SparePartOrder {
  id          String   @id @default(uuid())
  dealerId    String
  dealer      Dealer   @relation(fields: [dealerId], references: [id])
  partId      String
  quantity    Int
  totalAmount Float
  status      String   @default("Pending")
  createdAt   DateTime @default(now())
}

model Sale {
  id           String   @id @default(uuid())
  dealerId     String
  dealer       Dealer   @relation(fields: [dealerId], references: [id])
  scootersSold Int
  revenue      Float
  date         DateTime @default(now())
}

model Invoice {
  id        String  @id @default(uuid())
  orderId   String  @unique
  order     Order   @relation(fields: [orderId], references: [id])
  amount    Float
  gst       Float   @default(0.0)
  pdfUrl    String?
  status    String  @default("PENDING") // PENDING, PAID
}
