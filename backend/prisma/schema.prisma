// This is your Prisma schema file

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  phone     String
  password  String
  role          String         @default("DEALER") // ADMIN or DEALER
  dealer        Dealer?
  notifications Notification[]
  auditLogs     AuditLog[]
  createdAt     DateTime       @default(now())
}

model Dealer {
  id               String   @id @default(uuid())
  userId           String   @unique
  user             User     @relation(fields: [userId], references: [id])
  companyName      String
  address          String
  stock            Int      @default(0)
  performanceScore Float    @default(0.0)
  customers        Customer[]
  orders           Order[]
  sales            Sale[]
  sparePartOrders  SparePartOrder[]
  customerInvoices CustomerInvoice[]
  inventories      DealerInventory[]
}

model Scooter {
  id                    String   @id @default(uuid())
  sku                   String?  @unique
  model                 String   @unique
  category              String   @default("Standard") // Standard, Special, Commercial
  description           String?
  features              String?  // JSON string or comma-separated
  batteryCapacity       String?
  motorPower            String?
  maxSpeed              String?
  range                 String?
  chargingTime          String?
  controller            String?
  tyreSize              String?
  brakeType             String?
  suspension            String?
  weight                String?
  payload               String?
  colors                String?  // JSON array
  warrantyPeriod        String?
  dealerPrice           Float    @default(0.0)
  distributorPrice      Float    @default(0.0)
  retailPrice           Float    @default(0.0)
  manufacturingLeadTime String?  // e.g. "7 Days"
  quantity              Int      @default(0) // Available Stock
  manufacturedQuantity  Int      @default(0)
  reservedStock         Int      @default(0)
  dispatchedQuantity    Int      @default(0)
  reorderLevel          Int      @default(10)
  imageUrl              String?
  brochureUrl           String?
  updatedAt             DateTime @default(now()) @updatedAt
}

model Order {
  id              String   @id @default(uuid())
  dealerId        String
  dealer          Dealer   @relation(fields: [dealerId], references: [id])
  scooterModel    String
  quantity        Int
  color           String
  accessories     String?  // JSON string
  lineItems       String?  // JSON string for complex mixed orders
  deliveryAddress String
  paymentOption   String
  status          String   @default("Order Confirmed") // 14 steps
  trackingId      String?
  preferredDeliveryDate DateTime?
  expectedArrival DateTime?
  notes           String?
  subTotal        Float?
  gst             Float?
  totalAmount     Float?
  
  // Dispatch Details
  transportCompany String?
  driverName       String?
  driverMobile     String?
  vehicleNumber    String?
  lrNumber         String?
  dispatchDate     DateTime?
  
  invoice         Invoice?
  vehicles        Vehicle[] // Manufactured units
  createdAt       DateTime @default(now())
}

model Vehicle {
  id               String    @id @default(uuid())
  orderId          String
  order            Order     @relation(fields: [orderId], references: [id])
  scooterModel     String
  chassisNumber    String    @unique
  motorNumber      String    @unique
  batteryNumber    String    @unique
  controllerNumber String    @unique
  batchNumber      String
  productionDate   DateTime
  inspectionStatus String    @default("Pending") // Pending, Passed, Failed
  qrCodeData       String?
  warranty         Warranty?
}

model Warranty {
  id                String   @id @default(uuid())
  vehicleId         String   @unique
  vehicle           Vehicle  @relation(fields: [vehicleId], references: [id])
  dealerName        String
  purchaseDate      DateTime
  warrantyStartDate DateTime
  warrantyExpiryDate DateTime
  status            String   @default("Active") // Active, Claimed, Expired
}

model SparePart {
  id                   String   @id @default(uuid())
  sku                  String?  @unique
  name                 String
  category             String
  price                Float
  stock                Int      @default(0)
  manufacturedQuantity Int      @default(0)
  reservedStock        Int      @default(0)
  dispatchedQuantity   Int      @default(0)
  reorderLevel         Int      @default(10)
  description          String?
  imageUrl             String?
  updatedAt            DateTime @default(now()) @updatedAt
}

model SparePartOrder {
  id          String   @id @default(uuid())
  dealerId    String
  dealer      Dealer   @relation(fields: [dealerId], references: [id])
  partId      String
  quantity    Int
  totalAmount Float
  status      String   @default("Pending")
  createdAt   DateTime @default(now())
}

model Sale {
  id           String   @id @default(uuid())
  dealerId     String
  dealer       Dealer   @relation(fields: [dealerId], references: [id])
  scootersSold Int
  revenue      Float
  date         DateTime @default(now())
}

model Invoice {
  id        String  @id @default(uuid())
  orderId   String  @unique
  order     Order   @relation(fields: [orderId], references: [id])
  amount    Float
  gst       Float   @default(0.0)
  pdfUrl    String?
  status    String  @default("PENDING") // PENDING, PAID
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  title     String
  message   String
  type      String   @default("INFO") // INFO, SUCCESS, WARNING, ERROR
  read      Boolean  @default(false)
  link      String?  
  createdAt DateTime @default(now())
}

model Customer {
  id          String   @id @default(uuid())
  dealerId    String
  dealer      Dealer   @relation(fields: [dealerId], references: [id])
  name        String
  phone       String
  email       String?
  address     String?
  notes       String?
  purchaseDate DateTime?
  vehicleModel String?
  chassisNum   String?
  invoices    CustomerInvoice[]
  createdAt   DateTime @default(now())
}

model CustomerInvoice {
  id              String   @id @default(uuid())
  invoiceNumber   String   @unique
  dealerId        String
  dealer          Dealer   @relation(fields: [dealerId], references: [id])
  customerId      String?
  customer        Customer? @relation(fields: [customerId], references: [id])
  invoiceDate     DateTime @default(now())
  customerName    String
  customerPhone   String
  customerAddress String?
  
  // Old fields (made optional)
  scooterModel    String?
  scooterColor    String?
  chassisNumber   String?
  price           Float?
  gst             Float?
  
  // New flexible fields
  items           String?  // JSON stringified items array
  subtotal        Float?
  taxAmount       Float?
  
  totalAmount     Float
  warrantyDetails String?
  pdfUrl          String?
  createdAt       DateTime @default(now())
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id])
  role      String
  action    String
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())
}

model DealerInventory {
  id               String    @id @default(uuid())
  dealerId         String
  dealer           Dealer    @relation(fields: [dealerId], references: [id])
  productName      String
  productType      String    // "SCOOTER", "PART", "ACCESSORY"
  receivedQty      Int       @default(0)
  soldQty          Int       @default(0)
  availableQty     Int       @default(0)
  lastDispatchDate DateTime?
  lastOrderDate    DateTime?
  @@unique([dealerId, productName])
}

model InventoryMovement {
  id           String   @id @default(uuid())
  timestamp    DateTime @default(now())
  productName  String
  productType  String
  quantity     Int
  fromLocation String
  toLocation   String
  orderId      String?
  dispatchId   String?
  performedBy  String
  remarks      String?
}
